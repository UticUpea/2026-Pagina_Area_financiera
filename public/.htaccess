# =============================================================================
# .htaccess para Vue.js SPA - UPEA
# Seguridad y routing para Apache - VERSIÓN MEJORADA
# =============================================================================

# Bloquear acceso a archivos sensibles
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# HEADERS DE SEGURIDAD
<IfModule mod_headers.c>
    #  CSP mejorado: más restrictivo y con dominios específicos
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-TU7d8VZVY8JvPqVqJqVqJqVqJqVqJqVqJqVqJqVqJqV=' https://code.jquery.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data: blob:; connect-src 'self' https://apiadministrador.upea.bo https://servicioadministrador.upea.bo https://www.facebook.com; frame-src 'self' https://www.facebook.com https://www.youtube.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
    
    #  HSTS: Forzar HTTPS (ajusta max-age según necesites)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    
    # X-XSS-Protection está deprecated, pero lo dejamos por compatibilidad
    Header set X-XSS-Protection "1; mode=block"
    
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# Compresión GZIP (mejora performance)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Vue Router: modo history (sin proxy)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ index.html [L]
</IfModule>

# Cache para assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|ico|webp)$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public, immutable"
    </FilesMatch>
    # No cachear HTML para evitar problemas con actualizaciones
    <FilesMatch "\.html$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Configuración adicional
Options -Indexes
AddDefaultCharset UTF-8

#  Bloquear métodos HTTP peligrosos
<LimitExcept GET POST HEAD>
    Deny from all
</LimitExcept>

# Proteger archivos de configuración
<FilesMatch "\.(env|log|ini|sql|sh|bat|cmd)$">
    Order allow,deny
    Deny from all
</FilesMatch>